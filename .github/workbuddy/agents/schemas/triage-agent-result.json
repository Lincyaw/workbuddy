{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "priority",
    "needs_clarification"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["type:feature", "type:bug", "type:question"]
    },
    "priority": {
      "type": "string"
    },
    "assignee": {
      "type": "string"
    },
    "needs_clarification": {
      "type": "boolean"
    }
  }
}
